# ========================================
# 📧 CONFIGURATION MAIL CRITIQUE (SÉCURITÉ)
# ========================================
# Pour Gmail, utilisez un mot de passe d'application, pas votre mot de passe Gmail normal !
# Créer un mot de passe d'application: https://myaccount.google.com/apppasswords

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre_mot_de_passe_application_16_caracteres
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="votre-email@gmail.com"
MAIL_FROM_NAME="MIO Ressources"

# ========================================
# 🔄 CONFIGURATION QUEUE (IMPORTANT!)
# ========================================
# En PRODUCTION, utilisez 'database' ou 'redis' pour la persistance
# En LOCAL/DEV, vous pouvez utiliser 'sync' pour tester immédiatement

# Pour la production (RECOMMANDÉ):
QUEUE_CONNECTION=database

# Pour le développement local:
# QUEUE_CONNECTION=sync

# ========================================
# ⚙️ COMMANDES À LANCER EN PRODUCTION
# ========================================
# 1. Créer la table jobs: php artisan queue:table && php artisan migrate
# 2. Lancer le worker (en arrière-plan): php artisan queue:work --daemon
# 3. Tester le mail: php artisan mail:test votre-email@gmail.com
# 4. Voir la queue: php artisan queue:monitor
