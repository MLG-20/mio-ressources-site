APP_NAME="Mio Ressources"

# --- SUPER ADMIN (à changer obligatoirement en production) ---
ADMIN_NAME="Super Admin"
ADMIN_EMAIL=
ADMIN_PASSWORD=
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://votre-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mio_ressources
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@mio-ressources.me"
MAIL_FROM_NAME="Mio Ressources"

# --- EXEMPLES DE CONFIGURATION EMAIL POUR PRODUCTION ---
# Gmail :
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls

# MailerSend (recommandé) :
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailersend.net
# MAIL_PORT=587
# MAIL_USERNAME=MS_YOUR_API_TOKEN
# MAIL_PASSWORD=MS_YOUR_API_TOKEN
# MAIL_ENCRYPTION=tls

# --- PAYTECH ---
PAYTECH_API_KEY=
PAYTECH_API_SECRET=
PAYTECH_IPN_SECRET=
PAYTECH_ENV=prod

# --- JITSI ---
JITSI_DOMAIN=meet.jit.si
JITSI_LOBBY_ENABLED=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- BACKUP ---
BACKUP_ARCHIVE_PASSWORD=

# --- SENTRY (tracking d'erreurs en production) ---
# Créer un compte gratuit sur https://sentry.io puis coller le DSN ici
# Installer : composer require sentry/sentry-laravel
# Puis : php artisan sentry:publish
SENTRY_LARAVEL_DSN=
